<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="DishBook.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:DishBook"
    Title="DishBook">

    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate local:ViewPage}"
        Route="View" />
    
    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate local:AddPage}"
        Route="Add" />

    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate local:EditPage}"
        Route="Edit" />

    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate local:SearchPage}"
        Route="Search" />

</Shell>
